# AI powered Career Guidance system - Django Environment Configuration
# Copy this file to .env and update with your actual values

# Django Settings
SECRET_KEY=django-insecure-change-this-in-production-very-important
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL Database Configuration
DB_ENGINE=django.db.backends.postgresql
DB_NAME=evolvex_db
DB_USER=evolvex
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432

# LLM Configuration (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
LLM_MODEL=openai/gpt-oss-20b:free
LLM_TIMEOUT=120

# CORS Configuration (for frontend access)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000,http://127.0.0.1:8000

# Email Configuration (optional, for later)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Redis Configuration (optional, for caching/celery)
REDIS_URL=redis://localhost:6379/0

# Sentry Configuration (optional, for error tracking)
SENTRY_DSN=

# Logging Level
LOG_LEVEL=INFO

# Time Zone
TIME_ZONE=Asia/Kolkata
